DB_HOST=mysql
DB_PORT=3306
DB_USER=db_admin
DB_PASSWORD=replace-mysql-admin-password
DB_NAME=dbmanager
SESSION_SECRET=replace-with-strong-secret
SSL_CA=/app/certs/ca.pem
SSL_CERT=/app/certs/dashboard-cert.pem
SSL_KEY=/app/certs/dashboard-key.pem
PORT=8443
APP_BUILD_ID=dev
SKIP_INTERNAL_TLS=true
ALLOWED_ORIGINS=https://localhost:8443
DASHBOARD_SUPERADMIN_USERNAME=replace-superadmin-username
DASHBOARD_SUPERADMIN_PASSWORD=replace-superadmin-password
DASHBOARD_ADMIN_USERNAME=replace-admin-username
DASHBOARD_ADMIN_PASSWORD=replace-admin-password
DASHBOARD_USER_USERNAME=replace-user-username
DASHBOARD_USER_PASSWORD=replace-user-password
